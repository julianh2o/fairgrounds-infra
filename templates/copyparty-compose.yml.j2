services:
  copyparty:
    image: copyparty/ac:latest
    container_name: copyparty
    restart: unless-stopped
    ports:
      - 3923:3923
    volumes:
      - ./copyparty.conf:/cfg/copyparty.conf
      - /mnt/Store/sharedfiles:/data
      - ./hists:/cfg/hists
    command:
      - --xff-hdr=x-forwarded-for
      - --xff-src=10.10.0.0/16
      - --rproxy=1
